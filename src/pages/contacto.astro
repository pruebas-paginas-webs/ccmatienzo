---
import Layout from "../layouts/Layout.astro";
import { contact, faqs } from "../data/content";
---

<Layout title="Contacto">
  <!-- HERO -->
  <section class="pt-32 md:pt-44 pb-12 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Contacto</p>
      <h1 class="font-display uppercase text-7xl md:text-[10vw] leading-[0.9] reveal">
        Hablamos.
      </h1>
      <p class="text-paper/80 text-xl max-w-2xl mt-8 reveal">
        Estamos en Villa Crespo, abiertos desde las 20:00. Para shows, eventos y consultas.
      </p>
    </div>
  </section>

  <!-- 3 EMAILS -->
  <section class="px-6 md:px-12 py-16">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-px bg-paper/10">
      <a
        href={`mailto:${contact.emails.shows}`}
        class="bg-ink hover:bg-stone-100 p-8 md:p-10 group transition-colors"
      >
        <p class="text-magenta uppercase tracking-widest text-xs mb-6 font-bold">01 / Shows</p>
        <p class="text-3xl mb-3">🎵</p>
        <h3 class="font-display uppercase text-3xl md:text-4xl mb-3 group-hover:text-magenta transition-colors">
          Propuestas musicales
        </h3>
        <p class="text-paper/60 text-sm mb-6">Para bandas y artistas que quieran tocar.</p>
        <p class="text-paper border-b border-paper/30 group-hover:border-magenta inline-block pb-1 text-sm">
          {contact.emails.shows}
        </p>
      </a>

      <a
        href={`mailto:${contact.emails.eventos}`}
        class="bg-ink hover:bg-stone-100 p-8 md:p-10 group transition-colors"
      >
        <p class="text-magenta uppercase tracking-widest text-xs mb-6 font-bold">02 / Eventos</p>
        <p class="text-3xl mb-3">🎉</p>
        <h3 class="font-display uppercase text-3xl md:text-4xl mb-3 group-hover:text-magenta transition-colors">
          Festejos & Privados
        </h3>
        <p class="text-paper/60 text-sm mb-6">Para alquilar el espacio para tu evento.</p>
        <p class="text-paper border-b border-paper/30 group-hover:border-magenta inline-block pb-1 text-sm">
          {contact.emails.eventos}
        </p>
      </a>

      <a
        href={`mailto:${contact.emails.info}`}
        class="bg-ink hover:bg-stone-100 p-8 md:p-10 group transition-colors"
      >
        <p class="text-magenta uppercase tracking-widest text-xs mb-6 font-bold">03 / General</p>
        <p class="text-3xl mb-3">📧</p>
        <h3 class="font-display uppercase text-3xl md:text-4xl mb-3 group-hover:text-magenta transition-colors">
          Consultas generales
        </h3>
        <p class="text-paper/60 text-sm mb-6">Sugerencias, prensa, otras consultas.</p>
        <p class="text-paper border-b border-paper/30 group-hover:border-magenta inline-block pb-1 text-sm">
          {contact.emails.info}
        </p>
      </a>
    </div>
  </section>

  <!-- WHATSAPP BIG -->
  <section class="px-6 md:px-12 py-12">
    <a
      href={contact.whatsappUrl}
      target="_blank"
      rel="noopener"
      class="block max-w-7xl mx-auto bg-magenta text-ink p-10 md:p-16 hover:bg-neon transition-colors group"
    >
      <div class="flex items-center justify-between flex-wrap gap-6">
        <div>
          <p class="uppercase tracking-widest text-xs mb-3 font-bold">Atención inmediata</p>
          <h2 class="font-display uppercase text-5xl md:text-8xl leading-none group-hover:translate-x-2 transition-transform">
            Whatsapp →
          </h2>
        </div>
        <p class="font-display text-3xl md:text-5xl">{contact.phone}</p>
      </div>
    </a>
  </section>

  <!-- ADDRESS + MAP + INFO -->
  <section class="px-6 md:px-12 py-20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">¿Cómo llegar?</p>
        <h2 class="font-display uppercase text-5xl md:text-7xl mb-8 reveal leading-[0.9]">
          Villa Crespo, <br />CABA.
        </h2>
        <p class="font-display uppercase text-2xl mb-6 reveal">{contact.address}</p>

        <ul class="space-y-3 text-paper/70 reveal">
          <li class="flex items-start gap-3">
            <span class="text-magenta">▸</span> <span><strong class="text-paper">Subte:</strong> {contact.transport.subway}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-magenta">▸</span> <span><strong class="text-paper">Estacionamiento:</strong> {contact.transport.parking}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-magenta">▸</span> <span><strong class="text-paper">Atención:</strong> {contact.hours.attention}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-magenta">▸</span> <span><strong class="text-paper">Eventos:</strong> {contact.hours.open}</span>
          </li>
        </ul>

        <div class="mt-10 flex flex-wrap gap-4 reveal">
          <a href={contact.social.instagram} target="_blank" rel="noopener" class="border border-paper/30 hover:border-magenta hover:text-magenta px-4 py-2 text-sm uppercase tracking-wider transition">Instagram</a>
          <a href={contact.social.facebook} target="_blank" rel="noopener" class="border border-paper/30 hover:border-magenta hover:text-magenta px-4 py-2 text-sm uppercase tracking-wider transition">Facebook</a>
          <a href={contact.social.twitter} target="_blank" rel="noopener" class="border border-paper/30 hover:border-magenta hover:text-magenta px-4 py-2 text-sm uppercase tracking-wider transition">X / Twitter</a>
        </div>
      </div>

      <div class="aspect-[4/3] bg-stone-100 overflow-hidden reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.123!2d-58.4548!3d-34.5907!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcca4c5ac2d5f7%3A0x0!2sAv.%20Juan%20B.%20Justo%202959%2C%20Villa%20Crespo%2C%20CABA!5e0!3m2!1ses!2sar!4v1700000000000"
          class="w-full h-full grayscale-[0.6] contrast-[1.1] hover:grayscale-0 transition-all duration-500 border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Club Cultural Matienzo"></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-6 md:px-12 py-20 bg-stone-100/30 border-y border-paper/10">
    <div class="max-w-4xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Dudas frecuentes</p>
      <h2 class="font-display uppercase text-5xl md:text-7xl mb-12 reveal">FAQ</h2>

      <div class="space-y-4">
        {
          faqs.map((f) => (
            <details class="group border border-paper/15 hover:border-magenta/50 transition-colors reveal">
              <summary class="cursor-pointer flex items-center justify-between p-6 list-none">
                <span class="font-display text-xl md:text-2xl uppercase pr-4">{f.q}</span>
                <span class="text-magenta text-3xl group-open:rotate-45 transition-transform">+</span>
              </summary>
              <div class="px-6 pb-6 text-paper/80 leading-relaxed">{f.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
