---
import Layout from "../layouts/Layout.astro";
import Marquee from "../components/Marquee.astro";
import { tuEvento, contact } from "../data/content";
---

<Layout title="Tu Evento">
  <section class="relative pt-32 md:pt-44 pb-20 px-6 md:px-12 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/spaces/murales-interior.jpg" alt="" class="w-full h-full object-cover opacity-30" data-parallax="0.3" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink via-ink/70 to-ink"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Tu Evento</p>
      <h1 class="font-display uppercase text-7xl md:text-[10vw] leading-[0.85] reveal">
        Hacemos <br />tu evento <span class="text-magenta">soñado.</span>
      </h1>
      <p class="text-paper/80 text-xl max-w-2xl mt-8 reveal">
        Un equipo profesional, espacios versátiles y la energía del Matienzo a tu disposición.
      </p>
    </div>
  </section>

  <Marquee text="· Festejos · Corporativos · Producciones · Ferias " variant="magenta" repeat={6} />

  <!-- 4 panels -->
  <section class="px-6 md:px-12 py-20">
    <div class="max-w-7xl mx-auto space-y-px bg-paper/10">
      {
        tuEvento.map((cat, idx) => (
          <article
            class:list={[
              "group relative bg-ink hover:bg-stone-100 transition-colors duration-500 p-8 md:p-16 reveal",
            ]}
          >
            <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 items-start">
              <div>
                <p class="font-display text-7xl md:text-9xl text-magenta leading-none">{cat.code}</p>
                <p class="text-3xl mt-2">{cat.icon}</p>
              </div>
              <div>
                <h2 class="font-display uppercase text-4xl md:text-6xl mb-4 group-hover:translate-x-2 transition-transform duration-500">
                  {cat.title}
                </h2>
                <p class="text-paper/80 text-lg mb-6">{cat.short}</p>
                <ul class="grid grid-cols-2 gap-2 text-paper/60 text-sm">
                  {cat.items.map((it) => (
                    <li class="flex items-center gap-2">
                      <span class="w-1 h-1 bg-magenta block"></span>
                      {it}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="py-24 px-6 md:px-12 bg-stone-100/40 border-y border-paper/10">
    <div class="max-w-4xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Contanos tu idea</p>
      <h2 class="font-display uppercase text-5xl md:text-7xl mb-10 reveal">
        Conversemos.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a
          href={`mailto:${contact.emails.eventos}?subject=Consulta%20de%20evento`}
          class="block bg-ink border border-paper/20 hover:border-magenta p-8 transition-colors group"
        >
          <p class="text-magenta uppercase tracking-widest text-xs mb-3 font-bold">Por email</p>
          <p class="font-display text-3xl uppercase mb-2 group-hover:text-magenta transition-colors">
            {contact.emails.eventos}
          </p>
          <p class="text-paper/60 text-sm">Te respondemos en menos de 24h hábiles.</p>
        </a>
        <a
          href={contact.whatsapp ? `https://wa.me/541128372102?text=Hola%2C%20quisiera%20info%20sobre%20alquilar%20el%20espacio` : "#"}
          target="_blank"
          rel="noopener"
          class="block bg-magenta text-ink p-8 hover:bg-neon transition-colors group"
        >
          <p class="uppercase tracking-widest text-xs mb-3 font-bold">Por WhatsApp</p>
          <p class="font-display text-3xl uppercase mb-2">{contact.phone}</p>
          <p class="text-ink/70 text-sm">Atención inmediata, lun a dom 9-22.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const parallaxEls = document.querySelectorAll<HTMLElement>("[data-parallax]");
  let ticking = false;
  function update() {
    parallaxEls.forEach((el) => {
      const speed = parseFloat(el.dataset.parallax || "0.3");
      const rect = el.getBoundingClientRect();
      el.style.transform = `translate3d(0, ${-rect.top * speed * 0.2}px, 0)`;
    });
    ticking = false;
  }
  window.addEventListener("scroll", () => {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
</script>
