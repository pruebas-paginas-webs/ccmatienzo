---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.astro";
import Marquee from "../components/Marquee.astro";
import { events, eventCategories } from "../data/events";

// Group by date
const byDate = events.reduce<Record<string, typeof events>>((acc, ev) => {
  acc[ev.dateLabel] ??= [];
  acc[ev.dateLabel].push(ev);
  return acc;
}, {});
const dates = Object.keys(byDate);
---

<Layout title="Programación">
  <!-- HERO -->
  <section class="pt-32 md:pt-44 pb-12 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Agenda</p>
      <h1 class="font-display uppercase text-7xl md:text-[10vw] leading-[0.9] reveal">
        Programación
      </h1>
      <p class="text-paper/70 text-lg max-w-2xl mt-6 reveal">
        Recitales, fiestas, noches de juegos, ferias y propuestas audiovisuales. Toda la agenda del Club, semana a semana.
      </p>
    </div>
  </section>

  <Marquee text="· Programación · Live · Programación · Live " variant="outline" repeat={6} />

  <!-- LAYOUT: filters + agenda -->
  <section class="px-6 md:px-12 py-16 md:py-20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-10">
      <!-- Filters -->
      <aside class="lg:sticky lg:top-28 self-start">
        <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold">Filtrar por</p>
        <div class="flex flex-wrap lg:flex-col gap-2 mb-8">
          <button
            data-filter="all"
            class="filter-btn active text-left bg-magenta text-ink px-4 py-2.5 text-sm uppercase tracking-wider font-bold border border-magenta hover:bg-neon hover:border-neon transition"
          >
            Todos · {events.length}
          </button>
          {
            eventCategories.map((cat) => (
              <button
                data-filter={cat.name}
                class="filter-btn text-left bg-transparent text-paper px-4 py-2.5 text-sm uppercase tracking-wider font-bold border border-paper/30 hover:bg-paper hover:text-ink transition"
              >
                {cat.name} · {cat.count}
              </button>
            ))
          }
        </div>

        <div class="hidden lg:block border-t border-paper/10 pt-6 text-paper/50 text-xs">
          <p class="uppercase tracking-widest text-magenta mb-2 font-bold">¿Algo no ves?</p>
          <p>Reservas y consultas: WhatsApp +54 11 2837-2102</p>
        </div>
      </aside>

      <!-- Events list -->
      <div id="events-list" class="space-y-16">
        {
          dates.map((date) => (
            <div data-date-section>
              <h2 class="font-display uppercase text-4xl md:text-6xl mb-8 sticky top-20 bg-ink/80 backdrop-blur py-3 z-20 reveal">
                {date}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {byDate[date].map((event) => (
                  <div data-event-cat={event.category}>
                    <EventCard event={event} size="lg" />
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  import { loadEvents, hasOverride, eventCardHTML } from "../lib/eventStore";
  import { events as defaults } from "../data/events";

  function init() {
    // 1) HYDRATE from localStorage if admin made changes
    if (hasOverride()) {
      const evts = loadEvents(defaults);

      const byDate = new Map<string, typeof evts>();
      evts.forEach((e) => {
        if (!byDate.has(e.dateLabel)) byDate.set(e.dateLabel, []);
        byDate.get(e.dateLabel)!.push(e);
      });

      const list = document.getElementById("events-list");
      if (list) {
        list.innerHTML = Array.from(byDate.entries())
          .map(
            ([date, items]) => `<div data-date-section>
          <h2 class="font-display uppercase text-4xl md:text-6xl mb-8 sticky top-20 bg-ink/80 backdrop-blur py-3 z-20">${date}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            ${items.map((ev) => `<div data-event-cat="${ev.category}">${eventCardHTML(ev, "lg")}</div>`).join("")}
          </div>
        </div>`
          )
          .join("");
      }

      const counts: Record<string, number> = {};
      evts.forEach((e) => {
        counts[e.category] = (counts[e.category] || 0) + 1;
      });
      document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((b) => {
        const f = b.dataset.filter || "all";
        if (f === "all") {
          b.textContent = `Todos · ${evts.length}`;
        } else {
          b.textContent = `${f} · ${counts[f] || 0}`;
        }
      });
    }

    // 2) FILTER LOGIC (runs whether hydrated or not)
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const params = new URLSearchParams(window.location.search);
    const initialCat = params.get("cat") || "all";

    function applyFilter(cat: string) {
      document.querySelectorAll<HTMLElement>("[data-event-cat]").forEach((it) => {
        const itemCat = it.dataset.eventCat || "";
        const show = cat === "all" || itemCat === cat;
        it.style.display = show ? "" : "none";
      });
      document.querySelectorAll<HTMLElement>("[data-date-section]").forEach((sec) => {
        const visible = Array.from(sec.querySelectorAll<HTMLElement>("[data-event-cat]")).some(
          (el) => el.style.display !== "none"
        );
        sec.style.display = visible ? "" : "none";
      });
      buttons.forEach((b) => {
        const active = b.dataset.filter === cat;
        b.classList.toggle("active", active);
        b.classList.toggle("bg-magenta", active);
        b.classList.toggle("text-ink", active);
        b.classList.toggle("border-magenta", active);
        b.classList.toggle("text-paper", !active);
        b.classList.toggle("bg-transparent", !active);
        b.classList.toggle("border-paper/30", !active);
      });
    }

    buttons.forEach((b) => b.addEventListener("click", () => applyFilter(b.dataset.filter || "all")));
    applyFilter(initialCat);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
