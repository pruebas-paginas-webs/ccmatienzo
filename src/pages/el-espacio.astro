---
import Layout from "../layouts/Layout.astro";
import { spaces, contact } from "../data/content";
---

<Layout title="El Espacio">
  <!-- HERO -->
  <section class="relative pt-32 md:pt-44 pb-20 px-6 md:px-12 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/spaces/terraza-desde-arriba.jpg"
        alt=""
        class="w-full h-full object-cover opacity-30"
        data-parallax="0.3"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ink via-ink/70 to-ink"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">El Espacio</p>
      <h1 class="font-display uppercase text-7xl md:text-[10vw] leading-[0.9] reveal">
        1500 m² <br />
        <span class="text-magenta">de cultura</span>
      </h1>
      <p class="text-paper/80 text-xl max-w-2xl mt-8 reveal">
        Sala principal, bar y terraza. Tres espacios versátiles para shows, fiestas, ferias y eventos privados.
      </p>
    </div>
  </section>

  <!-- SPACES (split-screen pin per space) -->
  {
    spaces.map((sp, i) => (
      <section
        id={sp.slug}
        class:list={[
          "relative py-24 md:py-32 px-6 md:px-12 border-t border-paper/10",
          i % 2 === 0 ? "bg-ink" : "bg-stone-100/30",
        ]}
      >
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="lg:sticky lg:top-32">
            <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">
              Espacio {String(i + 1).padStart(2, "0")}
            </p>
            <h2 class="font-display uppercase text-6xl md:text-8xl leading-[0.9] mb-6 reveal">
              {sp.name}
            </h2>
            <p class="text-paper/80 text-lg leading-relaxed reveal">{sp.description}</p>
            {sp.slug === "terraza" && (
              <a
                href={contact.whatsappReservas}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-3 bg-magenta text-ink px-6 py-3 mt-8 font-bold uppercase tracking-wider hover:bg-neon transition reveal"
              >
                Reservar terraza →
              </a>
            )}
            {sp.slug === "bar" && (
              <a
                href="#"
                class="inline-flex items-center gap-3 border border-paper text-paper px-6 py-3 mt-8 font-bold uppercase tracking-wider hover:bg-paper hover:text-ink transition reveal"
              >
                Ver carta del bar →
              </a>
            )}
          </div>

          <div class="space-y-4">
            {sp.images.map((src, idx) => (
              <div class="overflow-hidden reveal" style={`transition-delay: ${idx * 80}ms`}>
                <img
                  src={src}
                  alt={`${sp.name} ${idx + 1}`}
                  class="w-full h-auto aspect-[4/3] object-cover hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <!-- CTA -->
  <section class="py-24 px-6 md:px-12 bg-magenta text-ink">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display uppercase text-5xl md:text-7xl mb-6">
        ¿Querés <span class="text-stroke" style="-webkit-text-stroke: 2px #000;">privatizar</span> el espacio?
      </h2>
      <p class="text-lg max-w-xl mx-auto mb-8 text-ink/80">
        Festejos, eventos corporativos, producciones audiovisuales y ferias.
      </p>
      <a
        href="/tu-evento"
        class="inline-flex items-center gap-3 bg-ink text-magenta px-8 py-4 font-bold uppercase tracking-wider hover:bg-paper hover:text-ink transition"
      >
        Ver servicios →
      </a>
    </div>
  </section>
</Layout>

<script>
  const parallaxEls = document.querySelectorAll<HTMLElement>("[data-parallax]");
  let ticking = false;
  function update() {
    parallaxEls.forEach((el) => {
      const speed = parseFloat(el.dataset.parallax || "0.3");
      const rect = el.getBoundingClientRect();
      el.style.transform = `translate3d(0, ${-rect.top * speed * 0.2}px, 0)`;
    });
    ticking = false;
  }
  window.addEventListener("scroll", () => {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
</script>
