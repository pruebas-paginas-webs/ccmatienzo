---
import Layout from "../layouts/Layout.astro";
import Marquee from "../components/Marquee.astro";
import { history, site } from "../data/content";
---

<Layout title="Nosotros">
  <!-- HERO -->
  <section class="pt-40 md:pt-52 pb-20 px-6 md:px-12 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Nosotros</p>
      <h1 class="font-display uppercase text-7xl sm:text-8xl md:text-[14rem] lg:text-[18rem] leading-[0.85] reveal">
        Desde<br /><span class="text-magenta">{site.yearFounded}.</span>
      </h1>
      <p class="text-paper/80 text-xl md:text-2xl max-w-3xl mt-12 leading-relaxed reveal">
        {history.intro}
      </p>
    </div>
  </section>

  <Marquee text="· 2008 · 2011 · 2012 · 2014 · 2018 · 2020 · 2023 · 2024 " variant="outline" repeat={3} />

  <!-- VERTICAL TIMELINE - magazine-style alternating -->
  <section class="px-6 md:px-12 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">La historia</p>
      <h2 class="font-display uppercase text-5xl md:text-7xl mb-20 leading-[0.9] reveal">
        15+ años. <br />8 hitos.
      </h2>

      <div class="relative">
        <!-- vertical line -->
        <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-paper/15 -translate-x-px hidden md:block"></div>

        <div class="space-y-24 md:space-y-32">
          {
            history.milestones.map((m, idx) => {
              const isRight = idx % 2 === 1;
              return (
                <article class:list={[
                  "relative grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center reveal",
                  isRight && "md:[&>*:first-child]:order-2"
                ]}>
                  {/* Image / accent */}
                  <div class:list={[
                    "relative",
                    isRight ? "md:pl-12" : "md:pr-12"
                  ]}>
                    {m.image ? (
                      <div class="overflow-hidden border border-paper/10">
                        <img
                          src={m.image}
                          alt={m.title}
                          class="w-full aspect-[4/3] object-cover hover:scale-105 transition-transform duration-700"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <div class="aspect-[4/3] flex items-center justify-center bg-magenta">
                        <span class="font-display text-[20vw] md:text-[12vw] text-ink leading-none">
                          {m.year}
                        </span>
                      </div>
                    )}
                  </div>

                  {/* Text */}
                  <div class:list={[
                    "relative",
                    isRight ? "md:pr-12 md:text-right" : "md:pl-12"
                  ]}>
                    <p class="font-display text-magenta text-7xl md:text-8xl leading-none mb-4">
                      {m.year}
                    </p>
                    <p class="text-paper/50 uppercase tracking-widest text-xs mb-3 font-bold">
                      Hito {String(idx + 1).padStart(2, "0")} / {history.milestones.length}
                    </p>
                    <h3 class="font-display uppercase text-3xl md:text-5xl mb-5 leading-[0.95]">
                      {m.title}
                    </h3>
                    <p class="text-paper/80 text-base md:text-lg leading-relaxed">
                      {m.description}
                    </p>
                  </div>

                  {/* Center dot (md+) */}
                  <span class="hidden md:block absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 rounded-full bg-magenta ring-8 ring-ink z-10"></span>
                </article>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-24 md:py-32 px-6 md:px-12 border-t border-paper/10 bg-stone-100/30">
    <div class="max-w-7xl mx-auto">
      <p class="text-magenta uppercase tracking-widest text-xs mb-4 font-bold reveal">Lo que hacemos</p>
      <h2 class="font-display uppercase text-5xl md:text-7xl mb-16 leading-[0.9] reveal">
        Más que <br />un boliche.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-paper/10">
        <div class="bg-ink p-8 md:p-10 reveal">
          <p class="text-magenta font-display text-5xl mb-4">01</p>
          <h3 class="font-display uppercase text-2xl mb-3">Plataforma</h3>
          <p class="text-paper/70 text-sm leading-relaxed">
            Para artistas consagrados y emergentes. Música, escena, performance, audiovisual.
          </p>
        </div>
        <div class="bg-ink p-8 md:p-10 reveal" style="transition-delay: 100ms">
          <p class="text-magenta font-display text-5xl mb-4">02</p>
          <h3 class="font-display uppercase text-2xl mb-3">Comunidad</h3>
          <p class="text-paper/70 text-sm leading-relaxed">
            80+ integrantes activos. MECA, Escena, ONG Abogados Culturales. Ley de Centros Culturales.
          </p>
        </div>
        <div class="bg-ink p-8 md:p-10 reveal" style="transition-delay: 200ms">
          <p class="text-magenta font-display text-5xl mb-4">03</p>
          <h3 class="font-display uppercase text-2xl mb-3">Medios</h3>
          <p class="text-paper/70 text-sm leading-relaxed">
            Radio Colmena, 24hs desde 2008. Talleres, laboratorios, ciclos formativos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BIG STATEMENT -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-magenta text-ink">
    <div class="max-w-5xl mx-auto">
      <p class="font-display uppercase text-4xl md:text-7xl leading-[0.95] reveal">
        Más de <span class="text-stroke" style="-webkit-text-stroke: 3px #000;">15 años</span> haciendo cultura independiente en Buenos Aires.
      </p>
    </div>
  </section>
</Layout>
